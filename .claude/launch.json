{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask Dev (app.py)",
      "runtimeExecutable": "venv/bin/python3",
      "runtimeArgs": ["app.py"],
      "port": 5002
    },
    {
      "name": "Flask Dev (main.py)",
      "runtimeExecutable": "venv/bin/python3",
      "runtimeArgs": ["main.py"],
      "port": 5001
    },
    {
      "name": "Gunicorn",
      "runtimeExecutable": "gunicorn",
      "runtimeArgs": ["--bind", "0.0.0.0:5000", "--reuse-port", "--reload", "main:app"],
      "port": 5000
    }
  ]
}
