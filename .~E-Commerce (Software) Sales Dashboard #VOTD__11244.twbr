          <datasource-dependencies datasource='federated.0zuz1tw1xgbavv1es02u90unkpyw'>
            <column caption='Prod. Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[CLV (copy)_1338976477651128320]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Avg CLV - Current&#13;&#10;SUM(IF NOT [is_refunded] &#13;&#10;THEN [net_revenue_usd] END)' />
            </column>
            <column caption='Current Period' datatype='boolean' name='[Calculation_1213157159435526148]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 547 THEN&#13;&#10;    &#13;&#10;    [event_date] &lt;= { FIXED : MAX([event_date]) }&#13;&#10;ELSE&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= 0&#13;&#10;END' />
            </column>
            <column caption='Index' datatype='integer' name='[Calculation_1840001932841086984]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='INDEX()'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Metric Calc.' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_640637060630335488]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN 1 THEN [CLV (copy)_1338976477651128320]&#13;&#10;WHEN 2 THEN [Prod. Revenue (copy)_1338976477658148866]&#13;&#10;WHEN 3 THEN [Prod. Quantity (copy)_1338976477659062275]&#13;&#10;END' />
            </column>
            <column caption='Category para. cal' datatype='boolean' name='[Calculation_640637060786593815]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[category] = [Parameters].[Category Parameter]' />
