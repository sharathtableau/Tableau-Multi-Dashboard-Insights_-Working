    <worksheet name='Avg. Days to 2nd by Channel'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#666666' fontname='Cambria' fontsize='9'>Top 3 Channels</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Customers (DataDNA Dataset Challenge - E-commerce Dataset - November 2025)' name='federated.0zuz1tw1xgbavv1es02u90unkpyw' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Last 21 Days' caption='Select Date' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='21'>
              <calculation class='tableau' formula='21' />
              <aliases>
                <alias key='7' value='Last 7 Days' />
                <alias key='14' value='Last 14 Days' />
                <alias key='21' value='Last 21 Days' />
                <alias key='30' value='Last 30 Days' />
                <alias key='90' value='Last 90 Days' />
                <alias key='547' value='Year to Date' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0zuz1tw1xgbavv1es02u90unkpyw'>
            <column caption='Second Purchase Date' datatype='datetime' name='[ First Purchase Date (copy)_808114670314786817]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='// Second Purchase Date&#13;&#10;{ FIXED [customer_id] : &#13;&#10;  MIN(IF [event_type] = &quot;order&quot; &#13;&#10;      AND NOT [is_refunded] &#13;&#10;      AND [event_date] &gt; [Calculation_808114670314459136]&#13;&#10;  THEN [event_date] END) &#13;&#10;}' />
            </column>
            <column caption='P.Days to Second Purchase' datatype='real' default-format='n#,##0&quot; days&quot;;-#,##0&quot; days&quot;' name='[C.Days to Second Purchase (copy)_808114670321188869]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Days to Second Purchase&#13;&#10;&#13;&#10;AVG(IF [Current Period (copy)_1213157159435792389] THEN&#13;&#10;DATEDIFF(&apos;day&apos;, [Calculation_808114670314459136], [ First Purchase Date (copy)_808114670314786817])&#13;&#10;END)' />
            </column>
            <column caption='C.AOV' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[C.Orders (copy)_350999307064033288]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1213157159441965062]/[Calculation_787566995935305728]' />
            </column>
            <column caption='C.Quantity' datatype='integer' default-format='n#,##0;-#,##0' name='[C.Total Revenue (copy)_1840001932864798745]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Calculation_1213157159435526148] &#13;&#10; AND NOT  [is_refunded]&#13;&#10;THEN  [quantity]&#13;&#10;END)' />
            </column>
            <column caption='CP. %Avg. Days to 2nd Purchase' datatype='real' default-format='*0.0%; 0.0%' name='[CP. %AOV (copy)_197313975166783490]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_808114670315163650] - [C.Days to Second Purchase (copy)_808114670321188869])/([C.Days to Second Purchase (copy)_808114670321188869])' />
            </column>
            <column caption='Current Period' datatype='boolean' name='[Calculation_1213157159435526148]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 547 THEN&#13;&#10;    &#13;&#10;    [event_date] &lt;= { FIXED : MAX([event_date]) }&#13;&#10;ELSE&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= 0&#13;&#10;END' />
            </column>
            <column caption='C.Total Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_1213157159441965062]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Calculation_1213157159435526148] &#13;&#10; AND NOT  [is_refunded]&#13;&#10;THEN  [net_revenue_usd]&#13;&#10;END)' />
            </column>
            <column caption='Index' datatype='integer' name='[Calculation_1840001932841086984]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='INDEX()'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='MIN(0)' datatype='integer' name='[Calculation_1840001932842614796]' role='measure' type='quantitative' user:unnamed='Sheet 3'>
              <calculation class='tableau' formula='MIN(0)' />
            </column>
            <column caption='MIN(0)' datatype='integer' name='[Calculation_1840001932843147280]' role='measure' type='quantitative' user:unnamed='Sheet 3'>
              <calculation class='tableau' formula='MIN(0)' />
            </column>
            <column caption='SIGN([CP. %Avg. Days to 2nd Purchase])' datatype='integer' name='[Calculation_197313975167160323]' role='measure' type='quantitative' user:unnamed='Avg. Days to vs. Channel'>
              <calculation class='tableau' formula='SIGN([CP. %AOV (copy)_197313975166783490])' />
            </column>
            <column caption='C.Orders' datatype='integer' name='[Calculation_787566995935305728]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF [Calculation_1213157159435526148] AND NOT [is_refunded]&#13;&#10;THEN [event_id]&#13;&#10;END)' />
            </column>
            <column caption=' First Purchase Date' datatype='datetime' name='[Calculation_808114670314459136]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='// First Purchase Date&#13;&#10;{ FIXED [customer_id] : &#13;&#10;  MIN(IF [event_type] = &quot;order&quot; AND NOT [is_refunded] &#13;&#10;  THEN [event_date] END) &#13;&#10;}' />
            </column>
            <column caption='C.Days to Second Purchase' datatype='real' default-format='n#,##0&quot; days&quot;;-#,##0&quot; days&quot;' name='[Calculation_808114670315163650]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Days to Second Purchase&#13;&#10;&#13;&#10;AVG(IF [Calculation_1213157159435526148] THEN&#13;&#10;DATEDIFF(&apos;day&apos;, [Calculation_808114670314459136], [ First Purchase Date (copy)_808114670314786817])&#13;&#10;END)' />
            </column>
            <column caption='Prior Period' datatype='boolean' name='[Current Period (copy)_1213157159435792389]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] != 547 THEN&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; 2 * [Parameters].[Parameter 1]&#13;&#10;END' />
            </column>
