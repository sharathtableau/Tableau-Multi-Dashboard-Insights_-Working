      </column>
      <column caption='Metric Calc.' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_640637060630335488]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN 1 THEN [CLV (copy)_1338976477651128320]&#13;&#10;WHEN 2 THEN [Prod. Revenue (copy)_1338976477658148866]&#13;&#10;WHEN 3 THEN [Prod. Quantity (copy)_1338976477659062275]&#13;&#10;END' />
      </column>
      <column caption='Color Selected Product' datatype='boolean' name='[Calculation_640637060780560396]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[product_name] = [Parameters].[Product Name Parameter]' />
      </column>
      <column caption='Category para. cal' datatype='boolean' name='[Calculation_640637060786593815]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[category] = [Parameters].[Category Parameter]' />
      </column>
      <column caption='C.Orders' datatype='integer' name='[Calculation_787566995935305728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Calculation_1213157159435526148] AND NOT [is_refunded]&#13;&#10;THEN [event_id]&#13;&#10;END)' />
      </column>
      <column caption=' First Purchase Date' datatype='datetime' name='[Calculation_808114670314459136]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='// First Purchase Date&#13;&#10;{ FIXED [customer_id] : &#13;&#10;  MIN(IF [event_type] = &quot;order&quot; AND NOT [is_refunded] &#13;&#10;  THEN [event_date] END) &#13;&#10;}' />
      </column>
      <column caption='C.Days to Second Purchase' datatype='real' default-format='n#,##0&quot; days&quot;;-#,##0&quot; days&quot;' name='[Calculation_808114670315163650]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Days to Second Purchase&#13;&#10;&#13;&#10;AVG(IF [Calculation_1213157159435526148] THEN&#13;&#10;DATEDIFF(&apos;day&apos;, [Calculation_808114670314459136], [ First Purchase Date (copy)_808114670314786817])&#13;&#10;END)' />
      </column>
      <column caption='Product para. cal' datatype='boolean' name='[Category para. cal (copy)_1803973140448051202]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[product_name] = [Parameters].[Product Name Parameter]' />
      </column>
      <column caption='Prior Period' datatype='boolean' name='[Current Period (copy)_1213157159435792389]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] != 547 THEN&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; 2 * [Parameters].[Parameter 1]&#13;&#10;END' />
      </column>
      <column caption='Is Loyal Customer' datatype='boolean' name='[Customer Total Order (copy)_350999307074154509]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Is Loyal Customer&#13;&#10;[Calculation_350999307073978380] &gt;= 2' />
      </column>
      <column caption='Loyal Customers' datatype='integer' name='[Customer Total Order (copy)_350999307074367502]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Loyal Customers - Current&#13;&#10;COUNTD( IF [Customer Total Order (copy)_350999307074154509]&#13;&#10;   AND [event_type] = &quot;order&quot;&#13;&#10;   AND NOT [is_refunded]&#13;&#10;THEN [customer_id]&#13;&#10;END)' />
      </column>
      <column caption='CLV' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Customer Total Revenue (copy)_1672524324871475201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Customer Lifetime Value&#13;&#10;AVG(IF [event_type] = &quot;order&quot;&#13;&#10;THEN [Calculation_1672524324870516736] END)' />
      </column>
      <column caption='Avg. Days to Second Purchase' datatype='real' default-format='n#,##0&quot; days&quot;;-#,##0&quot; days&quot;' name='[Days to Second Purchase (copy)_808114670319501315]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Days to Second Purchase&#13;&#10;AVG(DATEDIFF(&apos;day&apos;, [Calculation_808114670314459136], [ First Purchase Date (copy)_808114670314786817]))' />
      </column>
      <column caption='P.Gross Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Gross Revenue (copy)_350999307061026819]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM( IF [Current Period (copy)_1213157159435792389] AND NOT [is_refunded]&#13;&#10;THEN&#13;&#10;([net_revenue_local] + [tax_local] + [discount_local]) * [fx_rate_to_usd]&#13;&#10;END)' />
      </column>
      <column caption='Max. AOV' datatype='string' name='[Max. Quantity (copy)_350999307066716170]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [C.Orders (copy)_350999307064033288] = WINDOW_MAX([C.Orders (copy)_350999307064033288])&#13;&#10;THEN &apos;Max&apos;&#13;&#10;ELSE &apos;Others&apos;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Max. Avg. Days to Second Purchase' datatype='string' name='[Max. Quantity (copy)_808114670319947780]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Days to Second Purchase (copy)_808114670319501315] = WINDOW_MAX([Days to Second Purchase (copy)_808114670319501315])&#13;&#10;THEN &apos;Max&apos;&#13;&#10;ELSE &apos;Others&apos;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Max. Quantity' datatype='string' name='[Max. Total Revenue (copy)_1840001932874211358]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [C.Total Revenue (copy)_1840001932864798745] = WINDOW_MAX([C.Total Revenue (copy)_1840001932864798745])&#13;&#10;THEN &apos;Max&apos;&#13;&#10;ELSE &apos;Others&apos;&#13;&#10;END'>
