          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Last 21 Days' caption='Select Date' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='21'>
              <calculation class='tableau' formula='21' />
              <aliases>
                <alias key='7' value='Last 7 Days' />
                <alias key='14' value='Last 14 Days' />
                <alias key='21' value='Last 21 Days' />
                <alias key='30' value='Last 30 Days' />
                <alias key='90' value='Last 90 Days' />
                <alias key='547' value='Year to Date' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0zuz1tw1xgbavv1es02u90unkpyw'>
            <column caption='CP. +%Gross' datatype='real' default-format='*▲ 0.0%' name='[CP. +%Orders (copy)_350999307061432325]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ([Net Revenue  (copy)_436004750011314177] - [Gross Revenue (copy)_350999307061026819])/([Gross Revenue (copy)_350999307061026819]) &gt; 0&#13;&#10;THEN ([Net Revenue  (copy)_436004750011314177]- [Gross Revenue (copy)_350999307061026819])/([Gross Revenue (copy)_350999307061026819])&#13;&#10;END' />
            </column>
            <column caption='CP. -%Gross' datatype='real' default-format='*▼ 0.0%' name='[CP. -%Orders (copy)_350999307060899842]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ([Net Revenue  (copy)_436004750011314177] - [Gross Revenue (copy)_350999307061026819])/([Gross Revenue (copy)_350999307061026819]) &lt; 0&#13;&#10;THEN ABS([Net Revenue  (copy)_436004750011314177]- [Gross Revenue (copy)_350999307061026819])/([Gross Revenue (copy)_350999307061026819])&#13;&#10;END' />
            </column>
            <column caption='Current Period' datatype='boolean' name='[Calculation_1213157159435526148]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 547 THEN&#13;&#10;    &#13;&#10;    [event_date] &lt;= { FIXED : MAX([event_date]) }&#13;&#10;ELSE&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= 0&#13;&#10;END' />
            </column>
            <column caption='Prior Period' datatype='boolean' name='[Current Period (copy)_1213157159435792389]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] != 547 THEN&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; 2 * [Parameters].[Parameter 1]&#13;&#10;END' />
            </column>
            <column caption='P.Gross Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Gross Revenue (copy)_350999307061026819]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Current Period (copy)_1213157159435792389] AND NOT [is_refunded]&#13;&#10;THEN&#13;&#10;([net_revenue_local] + [tax_local] + [discount_local]) * [fx_rate_to_usd]&#13;&#10;END)' />
            </column>
            <column caption='C.Gross Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Net Revenue  (copy)_436004750011314177]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Calculation_1213157159435526148] AND NOT [is_refunded]&#13;&#10;THEN&#13;&#10;([net_revenue_local] + [tax_local] + [discount_local]) * [fx_rate_to_usd]&#13;&#10;END)' />
            </column>
            <column aggregation='CountD' caption='Discount Local' datatype='real' name='[discount_local]' role='dimension' type='quantitative' />
            <column caption='Event Date' datatype='datetime' name='[event_date]' role='dimension' type='ordinal' />
            <column caption='Fx Rate To Usd' datatype='real' name='[fx_rate_to_usd]' role='measure' type='quantitative' />
            <column caption='Is Refunded' datatype='boolean' name='[is_refunded]' role='dimension' type='nominal' />
            <column caption='Net Revenue Local' datatype='real' name='[net_revenue_local]' role='measure' type='quantitative' />
            <column caption='Product Name' datatype='string' name='[product_name]' role='dimension' type='nominal' />
            <column caption='Tax Local' datatype='real' name='[tax_local]' role='measure' type='quantitative' />
            <column-instance column='[CP. +%Orders (copy)_350999307061432325]' derivation='User' name='[usr:CP. +%Orders (copy)_350999307061432325:qk]' pivot='key' type='quantitative' />
            <column-instance column='[CP. -%Orders (copy)_350999307060899842]' derivation='User' name='[usr:CP. -%Orders (copy)_350999307060899842:qk]' pivot='key' type='quantitative' />
