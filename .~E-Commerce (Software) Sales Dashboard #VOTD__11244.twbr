        <calculation class='tableau' formula='COUNTD(IF [is_refunded] &#13;&#10;THEN [event_id] END) &#13;&#10;/&#13;&#10;COUNTD(IF [event_type] = &apos;order&apos;&#13;&#10;THEN [event_id] END)' />
