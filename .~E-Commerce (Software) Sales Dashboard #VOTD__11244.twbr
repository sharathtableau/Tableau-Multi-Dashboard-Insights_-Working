          <datasource-dependencies datasource='federated.0zuz1tw1xgbavv1es02u90unkpyw'>
            <column caption='CP. +%Net' datatype='real' default-format='*▲ 0.0%' name='[CP. +%Gross (copy)_350999307061702663]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ([Calculation_436004750011006976] - [Net Revenue  (copy)_350999307061145604])/([Net Revenue  (copy)_350999307061145604]) &gt; 0&#13;&#10;THEN ([Calculation_436004750011006976]- [Net Revenue  (copy)_350999307061145604])/([Net Revenue  (copy)_350999307061145604])&#13;&#10;END' />
            </column>
            <column caption='CP. -%Net' datatype='real' default-format='*▼ 0.0%' name='[CP. -%Gross (copy)_350999307061563398]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ([Calculation_436004750011006976] - [Net Revenue  (copy)_350999307061145604])/([Net Revenue  (copy)_350999307061145604]) &lt; 0&#13;&#10;THEN ABS([Calculation_436004750011006976]- [Net Revenue  (copy)_350999307061145604])/([Net Revenue  (copy)_350999307061145604])&#13;&#10;END' />
            </column>
            <column caption='Current Period' datatype='boolean' name='[Calculation_1213157159435526148]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 547 THEN&#13;&#10;    &#13;&#10;    [event_date] &lt;= { FIXED : MAX([event_date]) }&#13;&#10;ELSE&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= 0&#13;&#10;END' />
            </column>
            <column caption='C.Net Revenue ' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_436004750011006976]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Calculation_1213157159435526148] AND NOT [is_refunded]&#13;&#10;THEN&#13;&#10;[net_revenue_local] * [fx_rate_to_usd]&#13;&#10;END)' />
            </column>
            <column caption='Prior Period' datatype='boolean' name='[Current Period (copy)_1213157159435792389]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] != 547 THEN&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; 2 * [Parameters].[Parameter 1]&#13;&#10;END' />
            </column>
            <column caption='P.Net Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Net Revenue  (copy)_350999307061145604]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Current Period (copy)_1213157159435792389] AND NOT [is_refunded]&#13;&#10;THEN&#13;&#10;[net_revenue_local] * [fx_rate_to_usd]&#13;&#10;END)' />
            </column>
            <column caption='Event Date' datatype='datetime' name='[event_date]' role='dimension' type='ordinal' />
            <column caption='Fx Rate To Usd' datatype='real' name='[fx_rate_to_usd]' role='measure' type='quantitative' />
