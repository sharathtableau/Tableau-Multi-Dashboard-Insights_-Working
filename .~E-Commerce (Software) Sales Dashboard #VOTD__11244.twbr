            <run fontcolor='#666666' fontname='Cambria' fontsize='10'>&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Customers (DataDNA Dataset Challenge - E-commerce Dataset - November 2025)' name='federated.0zuz1tw1xgbavv1es02u90unkpyw' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Revenue' caption='Metric' datatype='integer' datatype-customized='true' name='[Parameter 2]' param-domain-type='list' role='measure' type='quantitative' value='1'>
              <calculation class='tableau' formula='1' />
              <aliases>
                <alias key='1' value='Revenue' />
                <alias key='2' value='Quantity' />
                <alias key='3' value='Customers' />
              </aliases>
            </column>
            <column caption='Product Name Parameter' datatype='string' name='[Product Name Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;Microsoft Copilot for Office Annual&quot;'>
              <calculation class='tableau' formula='&quot;Microsoft Copilot for Office Annual&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0zuz1tw1xgbavv1es02u90unkpyw'>
            <column caption='Prod. Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[CLV (copy)_1338976477651128320]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Avg CLV - Current&#13;&#10;SUM(IF NOT [is_refunded] &#13;&#10;THEN [net_revenue_usd] END)' />
            </column>
            <column caption='Metric Calc.' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_640637060630335488]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN 1 THEN [CLV (copy)_1338976477651128320]&#13;&#10;WHEN 2 THEN [Prod. Revenue (copy)_1338976477658148866]&#13;&#10;WHEN 3 THEN [Prod. Quantity (copy)_1338976477659062275]&#13;&#10;END' />
            </column>
            <column caption='Color Selected Product' datatype='boolean' name='[Calculation_640637060780560396]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[product_name] = [Parameters].[Product Name Parameter]' />
            </column>
            <column caption='Metric Calc. Symbol' datatype='string' name='[Metric Calc. (copy)_640637060630630401]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN 1 THEN &apos;$&apos;&#13;&#10;WHEN 2 THEN &apos; &apos;&#13;&#10;WHEN 3  THEN &apos; &apos;&#13;&#10;END' />
            </column>
            <column caption='Prod. Customers' datatype='integer' default-format='n#,##0;-#,##0' name='[Prod. Quantity (copy)_1338976477659062275]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF NOT [is_refunded] &#13;&#10;THEN [customer_id] END)' />
            </column>
            <column caption='Prod. Quantity' datatype='integer' default-format='n#,##0;-#,##0' name='[Prod. Revenue (copy)_1338976477658148866]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [event_type] = &apos;order&apos;&#13;&#10;AND NOT [is_refunded] &#13;&#10;THEN [quantity] END)' />
            </column>
            <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Customer Id' datatype='string' name='[customer_id]' role='dimension' type='nominal' />
            <column caption='Event Type' datatype='string' name='[event_type]' role='dimension' type='nominal' />
            <column caption='Is Refunded' datatype='boolean' name='[is_refunded]' role='dimension' type='nominal' />
            <column aggregation='CountD' caption='Net Revenue Usd' datatype='real' name='[net_revenue_usd]' role='measure' type='quantitative' />
