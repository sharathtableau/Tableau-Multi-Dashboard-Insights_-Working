      <datasource-dependencies datasource='Parameters'>
        <column caption='Category Parameter' datatype='string' name='[Category Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;AI Productivity&quot;'>
          <calculation class='tableau' formula='&quot;AI Productivity&quot;' />
        </column>
        <column alias='Last 21 Days' caption='Select Date' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='21'>
          <calculation class='tableau' formula='21' />
          <aliases>
            <alias key='7' value='Last 7 Days' />
            <alias key='14' value='Last 14 Days' />
            <alias key='21' value='Last 21 Days' />
            <alias key='30' value='Last 30 Days' />
            <alias key='90' value='Last 90 Days' />
            <alias key='547' value='Year to Date' />
          </aliases>
        </column>
        <column alias='Revenue' caption='Metric' datatype='integer' datatype-customized='true' name='[Parameter 2]' param-domain-type='list' role='measure' type='quantitative' value='1'>
          <calculation class='tableau' formula='1' />
          <aliases>
            <alias key='1' value='Revenue' />
            <alias key='2' value='Quantity' />
            <alias key='3' value='Customers' />
          </aliases>
        </column>
        <column caption='Show/hide' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;Show&quot;'>
          <calculation class='tableau' formula='&quot;Show&quot;' />
        </column>
        <column caption='Product Name Parameter' datatype='string' name='[Product Name Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;Microsoft Copilot for Office Annual&quot;'>
          <calculation class='tableau' formula='&quot;Microsoft Copilot for Office Annual&quot;' />
        </column>
