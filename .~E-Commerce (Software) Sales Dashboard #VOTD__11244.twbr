            </column>
            <column caption='CP. +%AOV' datatype='real' default-format='*▲ 0.0%' name='[CP. +%Quantity (copy)_350999307058647041]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ([C.Orders (copy)_350999307064033288] - [C.AOV (copy)_350999307064262665])/([C.AOV (copy)_350999307064262665]) &gt; 0&#13;&#10;THEN ([C.Orders (copy)_350999307064033288] - [C.AOV (copy)_350999307064262665])/([C.AOV (copy)_350999307064262665])&#13;&#10;END' />
