              <calculation class='tableau' formula='[C.Total Revenue (copy)_1213157159442825224]/[C.Orders (copy)_787566995935674369]' />
            </column>
            <column caption='C.AOV' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[C.Orders (copy)_350999307064033288]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1213157159441965062]/[Calculation_787566995935305728]' />
            </column>
            <column caption='P.Orders' datatype='integer' name='[C.Orders (copy)_787566995935674369]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF [Current Period (copy)_1213157159435792389] AND NOT [is_refunded]&#13;&#10;THEN [event_id]&#13;&#10;END)' />
            </column>
            <column caption='P.Total Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[C.Total Revenue (copy)_1213157159442825224]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Current Period (copy)_1213157159435792389]&#13;&#10; AND NOT  [is_refunded]&#13;&#10;THEN  [net_revenue_usd]&#13;&#10;END)' />
            </column>
            <column caption='C.Quantity' datatype='integer' default-format='n#,##0;-#,##0' name='[C.Total Revenue (copy)_1840001932864798745]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Calculation_1213157159435526148] &#13;&#10; AND NOT  [is_refunded]&#13;&#10;THEN  [quantity]&#13;&#10;END)' />
            </column>
            <column caption='CP. %AOV' datatype='real' default-format='*0.0%; 0.0%' name='[CP. %Quantity (copy)_197313975164694528]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([C.Orders (copy)_350999307064033288] - [C.AOV (copy)_350999307064262665])/([C.AOV (copy)_350999307064262665])' />
            </column>
            <column caption='Current Period' datatype='boolean' name='[Calculation_1213157159435526148]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = 547 THEN&#13;&#10;    &#13;&#10;    [event_date] &lt;= { FIXED : MAX([event_date]) }&#13;&#10;ELSE&#13;&#10;    DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &lt; [Parameters].[Parameter 1]&#13;&#10;    AND DATEDIFF(&apos;day&apos;, [event_date], { FIXED : MAX([event_date]) }) &gt;= 0&#13;&#10;END' />
            </column>
            <column caption='C.Total Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_1213157159441965062]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM( IF [Calculation_1213157159435526148] &#13;&#10; AND NOT  [is_refunded]&#13;&#10;THEN  [net_revenue_usd]&#13;&#10;END)' />
